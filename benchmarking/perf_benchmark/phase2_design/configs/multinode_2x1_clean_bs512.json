{
  "run_id": "phase3_multinode_2x1_clean_bs512",
  "output_root": "benchmarking/perf_benchmark/results",
  "require_cuda": true,
  "device": "auto",
  "steps": 1000,
  "warmup": 100,
  "repeats": 10,
  "gil_probe": false,
  "timing_modes": [
    "step"
  ],
  "cells": [
    "never_init",
    "trace_manual",
    "trace_auto"
  ],
  "workloads": [
    {
      "model": "tiny_mlp",
      "batch_size": 512,
      "dataloader": "synthetic"
    }
  ],
  "launch": {
    "nnodes": 2,
    "nproc_per_node": 1,
    "master_addr": "<NODE0_IP>",
    "master_port": 29500,
    "aggregator_port": 29765,
    "barrier_port": 29900,
    "rendezvous_timeout_sec": 120,
    "interval": 1.0,
    "finalize_timeout_sec": 300,
    "per_cell_timeout_sec": 900,
    "summary_window_rows": 2500
  }
}
