{
  "run_id": "phase3_single_gpu",
  "output_root": "benchmarking/perf_benchmark/results",
  "require_cuda": true,
  "device": "auto",
  "steps": 1000,
  "warmup": 100,
  "repeats": 3,
  "timing_modes": ["step", "phase"],
  "cells": ["never_init", "trace_manual", "trace_auto"],
  "workloads": [
    {
      "model": "tiny_mlp",
      "batch_size": 256,
      "dataloader": "synthetic"
    },
    {
      "model": "tiny_transformer",
      "batch_size": 8,
      "dataloader": "synthetic",
      "seq_len": 128,
      "hidden_dim": 384,
      "layers": 4
    }
  ],
  "launch": {
    "nnodes": 1,
    "nproc_per_node": 1,
    "master_addr": "127.0.0.1",
    "master_port": 29500,
    "aggregator_port": 29765,
    "interval": 1.0,
    "finalize_timeout_sec": 300,
    "per_cell_timeout_sec": 3600,
    "summary_window_rows": 2000
  }
}
